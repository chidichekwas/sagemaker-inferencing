{
  "Version": "2020-12-01",
  "Metadata": {},
  "Parameters": [
    {
      "Name": "InputData",
      "Type": "String",
      "DefaultValue": "s3://sagemaker-s3-chidi/fraud/processed/"
    },
    {
      "Name": "OutputS3",
      "Type": "String",
      "DefaultValue": "s3://sagemaker-s3-chidi/fraud/predictions/"
    }
  ],
  "PipelineExperimentConfig": {
    "ExperimentName": {
      "Get": "Execution.PipelineName"
    },
    "TrialName": {
      "Get": "Execution.PipelineExecutionId"
    }
  },
  "Steps": [
    {
      "Name": "InvokeFraudEndpoint",
      "Type": "Processing",
      "Arguments": {
        "ProcessingResources": {
          "ClusterConfig": {
            "InstanceType": "ml.t3.medium",
            "InstanceCount": 1,
            "VolumeSizeInGB": 30
          }
        },
        "AppSpecification": {
          "ImageUri": "683313688378.dkr.ecr.us-east-1.amazonaws.com/sagemaker-scikit-learn:1.2-1-cpu-py3",
          "ContainerEntrypoint": [
            "python3",
            "/opt/ml/processing/input/code/inference_script.py"
          ]
        },
        "RoleArn": "arn:aws:iam::148622480762:role/sagemaker-pipeline-role",
        "ProcessingInputs": [
          {
            "InputName": "input-data",
            "AppManaged": false,
            "S3Input": {
              "S3Uri": {
                "Get": "Parameters.InputData"
              },
              "LocalPath": "/opt/ml/processing/input",
              "S3DataType": "S3Prefix",
              "S3InputMode": "File",
              "S3DataDistributionType": "FullyReplicated",
              "S3CompressionType": "None"
            }
          },
          {
            "InputName": "code",
            "AppManaged": false,
            "S3Input": {
              "S3Uri": "s3://sagemaker-s3-chidi/fraud/scripts/inference_script.py",
              "LocalPath": "/opt/ml/processing/input/code",
              "S3DataType": "S3Prefix",
              "S3InputMode": "File",
              "S3DataDistributionType": "FullyReplicated",
              "S3CompressionType": "None"
            }
          }
        ],
        "ProcessingOutputConfig": {
          "Outputs": [
            {
              "OutputName": "predictions",
              "AppManaged": false,
              "S3Output": {
                "S3Uri": {
                  "Get": "Parameters.OutputS3"
                },
                "LocalPath": "/opt/ml/processing/output",
                "S3UploadMode": "EndOfJob"
              }
            }
          ]
        }
      }
    }
  ]
}